# ─── UPSTREAM PROVIDER ────────────────────────────────────────────────────────
# The base URL of any OpenAI-compatible endpoint.
# Remove the /v1 suffix — the proxy adds it.
#
# Examples:
#   OpenAI:          https://api.openai.com
#   NVIDIA NIM:      https://integrate.api.nvidia.com
#   Together AI:     https://api.together.xyz
#   Groq:            https://api.groq.com/openai
#   Azure OpenAI:    https://<resource>.openai.azure.com/openai/deployments/<deploy>
#   OpenRouter:      https://openrouter.ai/api
#   Ollama (local):  http://localhost:11434
UPSTREAM_BASE_URL=https://api.openai.com

# ─── API KEY ──────────────────────────────────────────────────────────────────
# Static key for the upstream provider.
UPSTREAM_API_KEY=sk-your-key-here

# OR set this to true to forward the x-api-key from the Claude Code request.
# Useful when multiple users each have their own key.
# UPSTREAM_API_KEY_PASSTHROUGH=false

# ─── MODEL MAPPING ────────────────────────────────────────────────────────────
# Explicit overrides: semicolon-separated "claude-model=provider-model" pairs.
# MODEL_MAP=claude-opus-4-6=gpt-4o;claude-haiku-4-5=gpt-4o-mini

# Catch-all fallbacks (used when no explicit MODEL_MAP entry matches):
BIG_MODEL=gpt-4o          # receives opus/sonnet requests
SMALL_MODEL=gpt-4o-mini   # receives haiku requests

# If set, requests with extended thinking enabled go to this model instead:
# REASONING_MODEL=o3

# ─── SERVER ───────────────────────────────────────────────────────────────────
PORT=8082
